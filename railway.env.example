# Obligatorio en producción (Railway → Variables):
NOMINATIM_PASSWORD=cambiar-por-secreto-fuerte

# Caché HTTP en nginx (activa por defecto). Desactivar: CACHE_ENABLED=false
# Nominatim: search/reverse/lookup cacheados 4 h en /nominatim/data/nginx-cache
# CACHE_ENABLED=true

# PBF local en volumen (ej. argentina-260618.osm.pbf subido a /nominatim/data):
# PBF_SOURCE_PATH=/nominatim/data/argentina-260618.osm.pbf

# salta = extracto provincia (recomendado) | argentina = país completo (32+ GB RAM)
# IMPORT_REGION=salta

# El resto tiene defaults en Dockerfile:
# SALTA_EXTRACT=true
# KEEP_ARGENTINA_PBF=true
# THREADS=2
# FREEZE=true
